---
const works = [
  "Atelier site, v3",
  "Capsule release",
  "Studio relaunch",
  "Year in review",
  "Brand system update",
  "Lookbook drop",
  "New work",
  "Process notes",
  "Field journal",
  "Edition no. 7",
  "Quiet release",
  "Archive opens",
  "Studio established",
];
---
<main class="page">
  <ul class="works" aria-label="works">
    {works.map((w) => (
      <li class="work">{w}</li>
    ))}
  </ul>
</main>

<style is:global>
  @font-face {
    font-family: "PSTLNC Neue";
    src:
      local("Helvetica Neue"),
      local("HelveticaNeue"),
      url("/fonts/HelveticaNeue.ttc") format("truetype-collection"),
      url("/fonts/HelveticaNeue.ttc") format("truetype");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  html, body {
    background: #d8d8d8;
    color: #0c0c0c;
    margin: 0;
  }
</style>

<style>
  .page {
    --paper: #d8d8d8;
    --ink: #0c0c0c;
    min-height: 100dvh;
    background: var(--paper);
    color: var(--ink);
    font-family: "PSTLNC Neue", "Helvetica Neue", Helvetica, Arial, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    display: flex;
    justify-content: center;
    align-items: center;
    padding:
      max(2rem, env(safe-area-inset-top))
      max(1.25rem, env(safe-area-inset-right))
      max(2rem, env(safe-area-inset-bottom))
      max(1.25rem, env(safe-area-inset-left));
    box-sizing: border-box;
  }

  .works {
    margin: 0;
    padding: 0;
    list-style: none;
    text-align: center;
    width: 100%;
    max-width: 44rem;
  }

  .work {
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.85;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-variant-numeric: lining-nums tabular-nums;
    color: var(--ink);
  }

  @media (min-width: 720px) {
    .work {
      font-size: 1.0625rem;
      line-height: 1.95;
      letter-spacing: 0.07em;
    }
  }
</style>
