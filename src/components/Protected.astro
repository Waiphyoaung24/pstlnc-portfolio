<style>
  .about {
    background: #d8d8d8;
    color: #0c0c0c;
    font-family: "PSTLNC Neue", "Helvetica Neue", Helvetica, Arial, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-align: center;
    padding:
      clamp(1.75rem, 5vh, 3.5rem)
      max(1.25rem, env(safe-area-inset-right))
      clamp(1.25rem, 3.5vh, 2.5rem)
      max(1.25rem, env(safe-area-inset-left));
  }
  .about__eyebrow {
    margin: 0;
    font-size: 0.8125rem;
