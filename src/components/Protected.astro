      clamp(0.5rem, 1.5vh, 1.25rem)
      max(1rem, env(safe-area-inset-right))
      clamp(0.5rem, 1.5vh, 1.25rem)
      max(1rem, env(safe-area-inset-left));
    box-sizing: border-box;
  }
  .dossier__img {
    width: 100%;
    height: auto;
    max-height: calc(100dvh - 4.5rem);
    object-fit: contain;
    display: block;
    margin: 0 auto;
  }

  .page {
    --paper: #d8d8d8;
    --ink: #0c0c0c;
    --bar-h: 4.5rem;
    background: var(--paper);
    color: var(--ink);
    font-family: "PSTLNC Neue", "Helvetica Neue", Helvetica, Arial, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(1.5rem, 4vh, 3rem);
    padding:
      clamp(1.25rem, 3.5vh, 2rem)
      max(1.25rem, env(safe-area-inset-right))
      clamp(2rem, 5vh, 3rem)
      max(1.25rem, env(safe-area-inset-left));
    box-sizing: border-box;
  }
  @media (min-width: 720px) {
    .page {
      min-height: calc(100dvh - var(--bar-h));
      justify-content: center;
    }
  }

  .catalog-header {
    width: 100%;
    max-width: 44rem;
  }
  .catalog-header__logo {
    display: block;
    width: 100%;
    height: auto;
    fill: #ea242a;
    margin: 0 0 clamp(0.875rem, 2.5vh, 1.75rem);
  }
  .catalog-header__heading {
    margin: 0;
    font-family: inherit;
    font-weight: 700;
    font-size: 1.0625rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink);
  }

  .works {
    margin: 0;
    padding: 0;
    list-style: none;
    text-align: left;
    width: 100%;
    max-width: 44rem;
  }

  .work {
    font-size: 1.0625rem;
    font-weight: 700;
    line-height: 1.55;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    font-variant-numeric: lining-nums tabular-nums;
    color: var(--ink);
  }

  .work__link {
    display: inline-block;
    position: relative;
    color: inherit;
    text-decoration: none;
    border-bottom: 0;
    padding: 0.55rem 0;
    cursor: pointer;
    transition: color 160ms ease;
    -webkit-tap-highlight-color: transparent;
  }
  .work__link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.18rem;
    height: 2px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 220ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .work__link:hover,
  .work__link:focus-visible {
    color: #ea242a;
  }
  .work__link:hover::after,
  .work__link:focus-visible::after {
    transform: scaleX(1);
  }
  .work__link:focus-visible {
    outline: 2px solid #ea242a;
    outline-offset: 4px;
  }
  .work__link:active {
    transform: translateY(1px);
  }
  @media (prefers-reduced-motion: reduce) {
    .work__link,
    .work__link::after {
      transition: none;
    }
