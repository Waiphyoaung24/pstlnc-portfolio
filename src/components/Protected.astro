<script is:inline>
  (function () {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    function init() {
      if (!window.gsap || !window.ScrollSmoother || !window.ScrollTrigger) return;
      if (window.ScrollSmoother.get()) return;
      if (!document.getElementById("smooth-wrapper")) return;
      window.gsap.registerPlugin(window.ScrollTrigger, window.ScrollSmoother);
      window.ScrollSmoother.create({
        wrapper: "#smooth-wrapper",
        content: "#smooth-content",
        smooth: 1.2,
        effects: true,
        // Match desktop smoothing on touch devices too.
        smoothTouch: 1.2,
        normalizeScroll: true,
        ignoreMobileResize: true,
      });
    }

    // Keep placeholder hash-only anchors from triggering scroll/URL change
    // while real destinations don't exist yet.
    document.addEventListener("click", function (e) {
      const a = e.target && e.target.closest && e.target.closest('a[href="#"]');
      if (a) e.preventDefault();
    });

    if (window.gsap && window.ScrollSmoother && window.ScrollTrigger) {
      init();
      return;
    }

    // Standalone render (dev /protected, no gate): bootstrap GSAP from CDN.
    const cdn = "https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/";
    const libs = ["gsap.min.js", "ScrollTrigger.min.js", "ScrollSmoother.min.js"];
    (function load(i) {
      if (i >= libs.length) return init();
      const s = document.createElement("script");
      s.src = cdn + libs[i];
      s.onload = () => load(i + 1);
      s.onerror = () => load(i + 1);
      document.head.appendChild(s);
    })(0);
  })();
</script>

<style is:global>
